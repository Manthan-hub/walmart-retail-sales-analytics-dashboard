          </zone-style>
        </zone>
        <zone forceUpdate='true' h='8969' id='117' type-v2='text' w='33333' x='38513' y='87416'>
          <formatted-text>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>Walmart generated </run>
            <run bold='true' fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>$6.73B</run>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'> in total sales during this period. </run>
            <run bold='true' fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>2011</run>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'> recorded the highest yearly sales, slightly surpassing 2010, while </run>
            <run bold='true' fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>2012</run>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'> saw a drop.</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='16710' id='120' type-v2='text' w='33438' x='1341' y='78663'>
          <formatted-text>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>Sales spike every </run>
            <run bold='true' fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>December</run>
            <run fontcolor='#75a1c7' fontname='Benton Sans Book' fontsize='11'>, likely due to holiday shopping.</run>
            <run>Æ&#10;&#10;</run>
