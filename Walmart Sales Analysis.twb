        <zone h='42838' id='22' name='Monthly Sales Trend by Year' w='35954' x='1341' y='34003'>
          <layout-cache minheight='290' type-h='scalable' type-w='fixed' />
          <zone-style>
            <format attr='border-color' value='#000000' />
